rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // Three-tier admin check, cheapest first:
      //   1. Custom claim `admin: true` (set via setAdminClaim Cloud Function)
      //   2. Hardcoded legacy fallback (founders) — kept as a safety net
      //   3. Email present in /settings/admins doc (manageable from the UI without rules deploy)
      return isAuthenticated() && (
        request.auth.token.admin == true ||
        isLegacyAdmin() ||
        isFirestoreAdmin()
      );
    }

    function isLegacyAdmin() {
      return request.auth.token.email != null &&
        request.auth.token.email.lower() in ['raju2uraju@gmail.com', 'kanthati.chakri@gmail.com'];
    }

    function isFirestoreAdmin() {
      // Reads /settings/admins. Field is `notificationEmails` (canonical) or `emails` (legacy).
      // settings/* is publicly readable, so no recursive auth issue.
      return request.auth.token.email != null &&
        exists(/databases/$(database)/documents/settings/admins) &&
        (
          request.auth.token.email.lower() in
            get(/databases/$(database)/documents/settings/admins).data.get('notificationEmails', []) ||
          request.auth.token.email.lower() in
            get(/databases/$(database)/documents/settings/admins).data.get('emails', [])
        );
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDeliveryAgent() {
      return isAuthenticated() && request.auth.token.delivery == true;
    }

    function validString(value, minLen, maxLen) {
      return value is string && 
        value.size() >= minLen && 
        value.size() <= maxLen;
    }
    
    function validNumber(value, min, max) {
      return value is number && 
        value >= min && 
        value <= max;
    }

    // Settings collection
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Products collection
    match /products/{productId} {
      allow read: if true;
      
      allow create: if isAdmin() && 
        validString(request.resource.data.name, 1, 100) &&
        validString(request.resource.data.unit, 1, 20) &&
        validNumber(request.resource.data.moq, 0, 10000) &&
        validNumber(request.resource.data.price, 0, 100000);
      
      allow update: if isAdmin() && 
        validString(request.resource.data.name, 1, 100) &&
        validString(request.resource.data.unit, 1, 20) &&
        validNumber(request.resource.data.moq, 0, 10000) &&
        validNumber(request.resource.data.price, 0, 100000);
      
      allow delete: if isAdmin();
    }
    
    // Orders collection
    match /orders/{orderId} {
      // Read: Admin reads all; buyers read their own; delivery agents read
      // orders assigned to them (so the delivery dashboard can list them).
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isDeliveryAgent() && resource.data.assignedTo == request.auth.uid);

      // Create: DISALLOWED from the client. Orders are created exclusively by
      // the submitOrder Cloud Function (Admin SDK), which enforces slab pricing,
      // MOQ, HORECA-tier gating, delivery-zone limits and the server-computed
      // total. A direct client write would bypass all of that, so it is denied.
      // (The old key-validation rule checked fields — items/total/address — that
      // real orders don't even use, so it validated nothing meaningful.)
      allow create: if false;

      // Update: Admin only. Delivery agents complete deliveries via the
      // completeDelivery Cloud Function (server-side, OTP-enforced) — they
      // never write order docs directly.
      allow update: if isAdmin();

      // Delete: Only admin
      allow delete: if isAdmin();
    }
    
    // Users collection
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      
      // Addresses subcollection
      match /addresses/{addressId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) &&
          validString(request.resource.data.name, 2, 50) &&
          validString(request.resource.data.phone, 10, 10) &&
          validString(request.resource.data.loc, 10, 200) &&
          validString(request.resource.data.pin, 6, 6);
      }
    }
    
    // Mail collection (for email extension)
    match /mail/{mailId} {
      allow create: if isAuthenticated();
      allow read, update, delete: if isAdmin();
    }
    
    // Pending orders for offline sync
    match /pendingOrders/{orderId} {
      allow create: if isAuthenticated() && 
        request.auth.uid == request.resource.data.userId;
      allow read, update, delete: if isAuthenticated() && 
        resource.data.userId == request.auth.uid;
    }
    
    // Analytics/Stats (admin only)
    match /stats/{statId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Notifications collection
    match /notifications/{notifId} {
      // Users can read their own notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admin can create notifications for any user
      allow create: if isAdmin();
      // Users can update their own notifications (mark as read)
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      // Admin can delete notifications
      allow delete: if isAdmin();
    }

    // Audit logs (admin only)
    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }
    
    // Rate limiting collection (internal use by Cloud Functions only)
    match /_rateLimits/{docId} {
      allow read, write: if false;
    }

    // Presence/Online status
    match /presence/{userId} {
      allow read: if isAdmin();
      allow create, update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if false;
    }

    // Stock purchases (admin only)
    match /stockPurchases/{purchaseId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Account entries — manual ledger entries (admin only)
    match /accountEntries/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Stores / Warehouses (admin only)
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Store Inventory (admin + agents for their own store)
    match /storeInventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Stock Transactions (admin + agents for their own store)
    match /stockTransactions/{txnId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Delivery Tracking tokens (public read by doc ID, admin write)
    match /deliveryTracking/{token} {
      allow read: if true;  // Public — customers access via token URL
      allow create, update, delete: if isAdmin();
    }

    // Announcements (admin creates, all authenticated users read)
    match /announcements/{annId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    // Grievances / User Messages
    match /grievances/{grvId} {
      // Users can read their own, admins can read all
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Authenticated users can create their own grievances
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll(['userId', 'subject', 'message', 'status']) &&
        request.resource.data.status == 'open';
      // Users can update their own (add replies); admins can update any (reply, change status)
      allow update: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Only admin can delete
      allow delete: if isAdmin();
    }

    // HORECA (Hotel/Restaurant/Catering) access requests
    // One request per account: the document id IS the applicant's uid, so a
    // user can never create a second request (prevents double submission) and
    // the claim is always granted to the exact account they applied from.
    match /horeca_requests/{requestId} {
      // Must be logged in; the doc id and requesterUid must be the caller's uid.
      allow create: if isAuthenticated() &&
        requestId == request.auth.uid &&
        request.resource.data.requesterUid == request.auth.uid &&
        request.resource.data.status == 'pending' &&
        validString(request.resource.data.contactName, 2, 100) &&
        validString(request.resource.data.businessName, 2, 200) &&
        validString(request.resource.data.phone, 10, 10);
      // Admin reads all; a user can read their own request to see its status.
      allow read: if isAdmin() ||
        (isAuthenticated() && requestId == request.auth.uid);
      // Admin can approve/reject. Owner may re-submit (only back to 'pending').
      allow update: if isAdmin() ||
        (isAuthenticated() && requestId == request.auth.uid &&
         request.resource.data.requesterUid == request.auth.uid &&
         request.resource.data.status == 'pending');
      // Admin can delete old requests
      allow delete: if isAdmin();
    }

    // Product requests — buyers ask for items missing from the catalog.
    // One shared collection (the catalog itself is not mode-namespaced).
    match /productRequests/{reqId} {
      // Signed-in users create their own request; must start as 'open'.
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'open' &&
        validString(request.resource.data.item, 2, 60);
      // Admin sees all; users can read their own requests.
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid);
      // Only admin resolves (added / dismissed) or deletes.
      allow update, delete: if isAdmin();
    }

    // Delivery OTP collection (Cloud Functions only)
    match /delivery_otps/{docId} {
      allow read, write: if false;  // Server-side only
    }

    // ─── Test Mode collections (prefixed duplicates) ───

    match /test_orders/{orderId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.userId == request.auth.uid) ||
        (isDeliveryAgent() && resource.data.assignedTo == request.auth.uid);
      // Created only by the submitOrder Cloud Function (Admin SDK) — see /orders.
      allow create: if false;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /test_stockPurchases/{purchaseId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /test_accountEntries/{entryId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /test_notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    match /test_stores/{storeId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /test_storeInventory/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test_stockTransactions/{txnId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /test_deliveryTracking/{token} {
      allow read: if true;  // Public — customers access via token URL
      allow create, update, delete: if isAdmin();
    }
  }
}
