rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Product images - publicly readable, no client-side writes
    // All uploads go through Cloud Functions using Admin SDK (bypasses rules)
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
